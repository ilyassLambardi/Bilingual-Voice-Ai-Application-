# ══════════════════════════════════════════════════════════
# Bilingual S2S Voice AI — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this to .env and fill in your API keys.

# ── Groq API (free tier: 30 RPM, ~14k tokens/day) ──────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ── Mode: "cloud" or "local" ────────────────────────────
# cloud = Groq APIs for LLM + ASR (no GPU needed, best quality)
# local = local models on GPU (needs VRAM, lower quality)
S2S_MODE=cloud

# ── Cloud LLM settings ──────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=150
LLM_TEMPERATURE=0.7

# ── Cloud ASR settings ──────────────────────────────────
ASR_MODEL=whisper-large-v3

# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
